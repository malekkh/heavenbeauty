# ---------------------------------------------------------------------------
# Heaven Beauty — environment variables
# Copy to `.env.local` and fill in. The app runs without these (it falls back
# to bundled seed data), but wire them up to use your real Supabase project.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose; guarded by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by the seed script and trusted server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL for metadata / WhatsApp links, e.g. https://myheavenbeauty.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: force a country in local dev where IP geolocation is empty.
# One of: jo, lb, ae, eg. Leave blank to use the default country (jo).
MOCK_COUNTRY=
