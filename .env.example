# ---------------------------------------------------------------------------
# Heaven Beauty — environment variables
# Copy to `.env.local` and fill in. The app runs without these (it falls back
# to bundled seed data), but wire them up to use your real Supabase project.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose; guarded by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by the seed script and trusted server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL for metadata / WhatsApp links, e.g. https://myheavenbeauty.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: force a country in local dev where IP geolocation is empty.
# One of: jo, lb, ae, eg. Leave blank to use the default country (jo).
MOCK_COUNTRY=

# ---------------------------------------------------------------------------
# Checkout notifications — SERVER ONLY. Never prefix these with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

# Resend API key for order emails (owner + customer confirmation).
# https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender for order emails. The domain must be verified in Resend
# (SPF/DKIM) before production or sends are rejected. Defaults to
# "Heaven Beauty <orders@myheavenbeauty.com>" if unset.
RESEND_FROM=

# Single fixed recipient for the owner order email (all countries). If unset,
# the owner email is skipped (order + customer email still go through).
OWNER_EMAIL=

# CallMeBot API key for the owner WhatsApp alert. Register the owner's number
# once at https://www.callmebot.com/blog/free-api-whatsapp-messages/ to get it.
# The alert is sent to each country's WhatsApp number (set in the admin).
CALLMEBOT_API_KEY=
